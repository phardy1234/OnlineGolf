{
  "name": "online-golf",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:all": "npm run build && npm install --prefix server && npm run build --prefix server",
    "start": "npm start --prefix server",
    "lint": "oxlint",
    "preview": "vite preview",
    "seed": "npm run seed --prefix server",
    "test:server": "npm test --prefix server",
    "test:e2e": "npm test --prefix e2e",
    "test:e2e:report": "npm run test:report --prefix e2e"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
