PORT=4100
NODE_ENV=development

# MongoDB Atlas connection string (include a database name in the path, e.g. /online-golf)
MONGODB_URI=

# Random 32+ byte secret, e.g. node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=7d
COOKIE_NAME=token

CORS_ORIGIN=http://localhost:5173

# Gmail app password (requires 2FA enabled on the Google account)
GMAIL_USER=
GMAIL_APP_PASSWORD=
CONTACT_RECIPIENT_EMAIL=
